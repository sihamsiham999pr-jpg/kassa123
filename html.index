<body>
  <div class="logo">فارسي يوسف</div>
  <div id="chat">
    <div id="messages"></div>
    <div id="input-area">
      <input id="input" type="text" placeholder="✍️ اكتب سؤالك..." />
      <button class="send-btn" onclick="sendMessage()">إرسال</button>
    </div>
  </div>
  <button id="clear-btn" onclick="clearChat()">🗑️</button>
  <div id="toast" class="toast">✅ تم نسخ نصك 👋</div>

  <script>
    const messagesDiv=document.getElementById("messages");
    const input=document.getElementById("input");

    const knowledgeBase={
      "من انت":["أنا يوسف فارسي 🤖، روبوت ذكاء اصطناعي هنا لمساعدتك."],
      "اسمك":["اسمي يوسف فارسي 🤖."],
      "مرحبا":["👋 أهلا وسهلا بك! كيف يمكنني مساعدتك؟"],
      "اهلا":["👋 أهلا وسهلا! كيف حالك؟"],
