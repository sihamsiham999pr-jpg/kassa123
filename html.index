      border-radius:25px; box-shadow:0 10px 50px rgba(0,0,0,0.3);
      display:flex; flex-direction:column; overflow:hidden;
      border:1px solid rgba(255,255,255,0.1); margin-bottom:20px;}
    #messages {flex:1; padding:15px; overflow-y:auto; display:flex; flex-direction:column; gap:10px;
      scroll-behavior:smooth; max-height:70vh;}
    #messages::-webkit-scrollbar {width:8px;}
    #messages::-webkit-scrollbar-thumb {background-color:var(--primary-color); border-radius:10px;}
    #messages::-webkit-scrollbar-track {background-color:rgba(255,255,255,0.05);}
    .msg {margin:8px; padding:12px 18px; border-radius:25px; max-width:75%;
      line-height:1.4; word-break:break-word; box-shadow:0 4px 10px rgba(0,0,0,0.2);
      user-select:text; -webkit-user-select:text; cursor:text; position:relative;}
    .user {background:linear-gradient(135deg,#1abc9c,#2980b9); color:#fff; margin-left:auto;
      border-top-left-radius:25px; border-bottom-left-radius:25px; border-bottom-right-radius:8px;}
    .bot {background:linear-gradient(135deg,#2c3e50,#34495e); color:var(--font-color-light);
      margin-right:auto; border-top-right-radius:25px; border-bottom-right-radius:25px;
      border-bottom-left-radius:8px; position:relative; padding-right:35px;}
    .bot::before {content:'🤖'; position:absolute; top:-15px; right:-10px; font-size:1.5em;
      opacity:0.5; color:var(--primary-color); transform:rotate(10deg);}
    .copy-btn {position:absolute; top:-15px; right:-15px; background:var(--primary-color); border:none;
      color:#fff; font-size:16px; cursor:pointer; padding:6px 10px; border-radius:50%;
      box-shadow:0 2px 6px rgba(0,0,0,0.2);}
    #input-area {display:flex; border-top:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05);}
    #input {flex:1; border:none; padding:15px; font-size:16px; outline:none; background:transparent; color:var(--font-color-light);}
    #input::placeholder {color:rgba(255,255,255,0.5);}
    button {border:none; padding:0 20px; cursor:pointer; font-size:18px; background:transparent; color:var(--font-color-light);}
    .send-btn {background:var(--primary-color); color:#fff;}
    #clear-btn {background:var(--danger-color); color:#fff; border-radius:12px; font-size:22px;
      padding:10px 30px; box-shadow:0 4px 10px rgba(0,0,0,0.3); border:none; cursor:pointer; transition:transform 0.2s ease-in-out;}
    #clear-btn:hover {transform:scale(1.05);}
    .toast {visibility:hidden; min-width:220px; background-color:#333; color:#fff; text-align:center;
      border-radius:12px; padding:12px; position:fixed; bottom:30px; right:30px; font-size:16px;
      box-shadow:0 4px 10px rgba(0,0,0,0.3); opacity:0; transform:translateY(20px);
      transition:all 0.5s ease; z-index:1000;}
    .toast.show {visibility:visible; opacity:1; transform:translateY(0);}
  </style>
